# ============================================
# SUTRA Core - Production Environment Template
# ============================================
# IMPORTANT: This is a template file. DO NOT use directly in production.
# Use the generate_production_secrets.py script to generate actual secrets.
# ============================================

# Application
APP_NAME=SUTRA Core
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ============================================
# SECURITY SECRETS
# ============================================

# Encryption Key (AES-256)
# Generate using: python scripts/generate_production_secrets.py
ENCRYPTION_KEY=GENERATE_SECURE_KEY_HERE

# JWT Secret
# Generate using: python scripts/generate_production_secrets.py
SECRET_KEY=GENERATE_SECURE_SECRET_HERE

# Webhook Verify Token
# Generate using: python scripts/generate_production_secrets.py
META_VERIFY_TOKEN=GENERATE_VERIFY_TOKEN_HERE

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://sutra_user:CHANGE_THIS_PASSWORD@localhost:5432/sutra_db

# Database Pool Settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# ============================================
# REDIS CONFIGURATION
# ============================================

# Redis URL
# Format: redis://:password@host:port/database
REDIS_URL=redis://:CHANGE_THIS_PASSWORD@localhost:6379/0

# Redis Pool Settings
REDIS_POOL_SIZE=20
REDIS_STREAM_MAX_LEN=10000

# ============================================
# META WHATSAPP CLOUD API
# ============================================

# Meta App Configuration
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PHONE_NUMBER_ID=your_meta_phone_number_id
META_ACCESS_TOKEN=your_meta_access_token
META_WEBHOOK_URL=https://api.sutra.com/api/v1/webhooks/whatsapp

# ============================================
# LLM API CONFIGURATION
# ============================================

# OpenAI API Key (for Whisper STT)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Gemini API Key (for agent reasoning)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# Groq API Key (fallback / fast inference)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# ============================================
# MULTI-TENANCY
# ============================================

DEFAULT_TENANT_ID=default
TENANT_ISOLATION_ENABLED=true

# ============================================
# GST CONFIGURATION
# ============================================

# Default GST State Code
# 24 = Gujarat, 27 = Maharashtra, etc.
DEFAULT_GST_STATE_CODE=24

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================
# MONITORING
# ============================================

MONITORING_ENABLED=true
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# ============================================
# BACKUP CONFIGURATION
# ============================================

BACKUP_ENABLED=true
# Backup schedule (cron format): 0 2 * * * = daily at 2 AM
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/var/backups/sutra

# ============================================
# ALERTS
# ============================================

# Restock alert threshold
RESTOCK_THRESHOLD_UNITS=10

# Udhaar (credit) alert threshold in days
UDHAAR_ALERT_DAYS=30

# ============================================
# PERFORMANCE
# ============================================

# Maximum request size in bytes (10MB)
MAX_REQUEST_SIZE=10485760

# Maximum webhook retries
MAX_WEBHOOK_RETRIES=3

# Webhook timeout in seconds
WEBHOOK_TIMEOUT=30

# ============================================
# CORS CONFIGURATION
# ============================================

# Update with your production frontend domains
CORS_ORIGINS=["https://dashboard.sutra.com","https://api.sutra.com"]

# ============================================
# TESTING
# ============================================

TEST_MODE=false

# ============================================
# PRODUCTION SETUP INSTRUCTIONS
# ============================================
#
# 1. Generate secure secrets:
#    python scripts/generate_production_secrets.py
#
# 2. Update placeholder values:
#    - DATABASE_URL with your production database credentials
#    - REDIS_URL with your production Redis credentials
#    - META_* with your Meta WhatsApp Cloud API credentials
#    - OPENAI_API_KEY with your OpenAI API key
#    - GEMINI_API_KEY with your Gemini API key
#    - GROQ_API_KEY with your Groq API key
#    - CORS_ORIGINS with your production frontend domains
#
# 3. Set file permissions:
#    chmod 600 .env.production
#
# 4. Deploy to production:
#    docker-compose -f docker-compose.prod.yml up -d
#
# 5. Run database migrations:
#    docker-compose -f docker-compose.prod.yml exec app alembic upgrade head
#
# 6. Verify deployment:
#    curl https://api.sutra.com/health/
#
# ============================================
# SECURITY BEST PRACTICES
# ============================================
#
# 1. Never commit .env.production to version control
# 2. Use a secrets manager (AWS Secrets Manager, HashiCorp Vault)
# 3. Rotate secrets regularly (every 90 days recommended)
# 4. Use strong, unique passwords
# 5. Enable SSL/TLS for all connections
# 6. Regular security audits
# 7. Monitor for unauthorized access
# 8. Keep dependencies updated
#
# ============================================
